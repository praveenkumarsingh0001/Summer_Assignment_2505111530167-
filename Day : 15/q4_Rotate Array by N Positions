#include <stdio.h>

int main() {
    int arr[100], n, k, i, j, first;

    printf("Enter the size of array: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);

    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter number of rotations: ");
    scanf("%d", &k);

    k = k % n;

    for(j = 1; j <= k; j++) {
        first = arr[0];

        for(i = 0; i < n - 1; i++) {
            arr[i] = arr[i + 1];
        }

        arr[n - 1] = first;
    }

    printf("Array after rotating by %d positions:\n", k);

    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
