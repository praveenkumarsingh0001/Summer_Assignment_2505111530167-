#include <stdio.h>

int main() {
    int arr[100], n, i;
    int sum = 0, total, missing;

    printf("Enter the value of n (numbers from 1 to n): ");
    scanf("%d", &n);

    printf("Enter %d numbers:\n", n - 1);

    for(i = 0; i < n - 1; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
    }

    total = n * (n + 1) / 2;
    missing = total - sum;

    printf("Missing Number = %d", missing);

    return 0;
}
