#include <stdio.h>

int main() {
    int choice, id[100], n = 0, i;
    char book[100][50];

    do {
        printf("\n===== Library Management System =====\n");
        printf("1. Add Book\n");
        printf("2. View Books\n");
        printf("3. Exit\n");

        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter Book ID: ");
            scanf("%d", &id[n]);

            printf("Enter Book Name: ");
            scanf("%s", book[n]);

            n++;
            printf("Book Added Successfully\n");
            break;

        case 2:
            printf("\nBook Records\n");
            for(i = 0; i < n; i++) {
                printf("ID: %d\tBook: %s\n", id[i], book[i]);
            }
            break;

        case 3:
            printf("Thank You\n");
            break;

        default:
            printf("Invalid Choice\n");
        }

    } while(choice != 3);

    return 0;
}
