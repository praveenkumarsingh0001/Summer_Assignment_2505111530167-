#include <stdio.h>

int main() {
    int choice, n = 0, i;
    char name[100][50];
    char phone[100][15];

    do {
        printf("\n===== Contact Management System =====\n");
        printf("1. Add Contact\n");
        printf("2. View Contacts\n");
        printf("3. Exit\n");

        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter Name: ");
            scanf("%s", name[n]);

            printf("Enter Phone Number: ");
            scanf("%s", phone[n]);

            n++;
            printf("Contact Saved Successfully\n");
            break;

        case 2:
            printf("\nContact List\n");

            for(i = 0; i < n; i++) {
                printf("%d. %s - %s\n", i + 1, name[i], phone[i]);
            }
            break;

        case 3:
            printf("Thank You\n");
            break;

        default:
            printf("Invalid Choice\n");
        }

    } while(choice != 3);

    return 0;
}
