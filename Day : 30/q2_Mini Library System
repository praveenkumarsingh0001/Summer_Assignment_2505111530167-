#include <stdio.h>

int main() {
    int id[100], n = 0, i, choice;
    char book[100][50], author[100][50];

    do {
        printf("\n===== Mini Library System =====\n");
        printf("1. Add Book\n");
        printf("2. View Books\n");
        printf("3. Exit\n");

        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter Book ID: ");
            scanf("%d", &id[n]);

            printf("Enter Book Name: ");
            scanf("%s", book[n]);

            printf("Enter Author Name: ");
            scanf("%s", author[n]);

            n++;
            printf("Book Added Successfully\n");
            break;

        case 2:
            for(i = 0; i < n; i++) {
                printf("\nBook ID : %d", id[i]);
                printf("\nBook    : %s", book[i]);
                printf("\nAuthor  : %s\n", author[i]);
            }
            break;

        case 3:
            printf("Thank You\n");
            break;

        default:
            printf("Invalid Choice\n");
        }

    } while(choice != 3);

    return 0;
}
